# Prefer the CMake compilation database (absolute -I paths, -std=c++20, -Werror).
# Per-directory compile_flags.txt under simulator/src/{core,physics,engine}/ and
# simulator/tests/ cover the case where a header is opened before CMake configure.
CompileFlags:
  CompilationDatabase: simulator/build
  Add:
    - -Wno-pragma-once-outside-header

Diagnostics:
  Suppress:
    - pragma-once-outside-header
  # Translation units include their matching public header (umbrella style).
  # Strict IWYU MissingIncludes/UnusedIncludes floods Problems without catching
  # real build failures (-Werror already guards the compiler).
  UnusedIncludes: None
  MissingIncludes: None

Index:
  Background: Build
