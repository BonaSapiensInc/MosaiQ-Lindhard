{
    "cSpell.configPath": "cspell.json",
    "cSpell.enabledLanguageIds": [
        "latex",
        "markdown",
        "plaintext",
        "python",
        "scminput",
        "cpp",
        "c"
    ],

    "C_Cpp.default.cppStandard": "c++20",
    "C_Cpp.default.compileCommands": "${workspaceFolder}/compile_commands.json",
    "C_Cpp.intelliSenseEngine": "disabled",
    "C_Cpp.errorSquiggles": "disabled",
    "C_Cpp.autocomplete": "disabled",
    "C_Cpp.formatting": "disabled",
    "C_Cpp.autoAddFileAssociations": false,

    "clangd.path": "clangd",
    "clangd.arguments": [
        "--header-insertion=never",
        "--compile-commands-dir=${workspaceFolder}/simulator/build"
    ],
    "clangd.onConfigChanged": "restart",

    "clang.diagnostic.enable": false,
    "clang.completion.enable": false,
    "clang.executable": "",
    "clang.cxxflags": [
        "-std=c++20",
        "-I${workspaceFolder}/simulator/src",
        "-Wno-pragma-once-outside-header"
    ],
    "clang.cflags": [
        "-std=c17",
        "-I${workspaceFolder}/simulator/src"
    ],

    "cmake.sourceDirectory": "${workspaceFolder}/simulator",
    "cmake.buildDirectory": "${workspaceFolder}/simulator/build",

    "latex-workshop.latex.rootFile": "manuscript/two-fermi.tex",
    "latex-workshop.linting.chktex.enabled": false,
    "latex-workshop.linting.lacheck.enabled": false,
    "latex-workshop.message.badbox.show": "none",
    "latex-workshop.message.biberlog.show": false,
    "latex-workshop.message.bibtexlog.show": false,
    "latex-workshop.message.latexlog.show": false,

    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.terminal.activateEnvironment": true
}
