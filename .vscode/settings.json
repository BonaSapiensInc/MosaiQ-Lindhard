    "C_Cpp.default.cppStandard": "c++20",
    "C_Cpp.default.compileCommands": "${workspaceFolder}/compile_commands.json",
    "C_Cpp.intelliSenseEngine": "disabled",
    "C_Cpp.errorSquiggles": "disabled",
    "C_Cpp.autocomplete": "disabled",
    "clangd.arguments": [
        "--header-insertion=never"
    ],
    "cmake.sourceDirectory": "${workspaceFolder}/simulator",
    "cmake.buildDirectory": "${workspaceFolder}/simulator/build",
    "latex-workshop.latex.rootFile": "manuscript/two-fermi.tex",
    "latex-workshop.linting.chktex.enabled": false,
    "latex-workshop.linting.lacheck.enabled": false,
    "latex-workshop.message.badbox.show": "none",
    "latex-workshop.message.biberlog.show": false,
    "latex-workshop.message.bibtexlog.show": false,
    "latex-workshop.message.latexlog.show": false,
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.terminal.activateEnvironment": true
