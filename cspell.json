{
  "version": "0.2",
  "language": "en",
  "ignorePaths": [
    "**/*.dat",
    "**/*.pdf",
    "**/*.pyc",
    "**/*.zip",
    "**/.cache/**",
    "**/__pycache__/**",
    "**/node_modules/**",
    ".venv/**",
    ".vscode/settings.json",
    "compile_commands.json",
    "docs/legacy_extraction/**",
    "docs/references/**",
    "manuscript/*.aux",
    "manuscript/*.bbl",
    "manuscript/*.blg",
    "manuscript/*.log",
    "manuscript/*.out",
    "manuscript/submission.zip",
    "output/**/*.dat",
    "simulator/build/**",
    "simulator/output/**"
  ],
  "ignoreRegExpList": [
    "\\\\[a-zA-Z@]+(?:\\*?)?",
    "\\\\\\([^)]*\\\\\\)",
    "-D[A-Z]+",
    "\"[^\"\\\\]*(?:\\\\.[^\"\\\\]*)*\"",
    "'[^'\\\\]*(?:\\\\.[^'\\\\]*)*'"
  ],
  "languageSettings": [
    {
      "languageId": "latex",
      "caseSensitive": false,
      "ignoreRegExpList": [
        "[A-Za-z-]+\\\\\"[a-zA-Z]+(?:[a-z]+)?",
        "[A-Za-z-]+\\\\'[a-zA-Z]+(?:[a-z]+)?",
        "[A-Za-z-]+\\\\\\^[a-zA-Z]+(?:[a-z]+)?",
        "[A-Za-z-]+\\\\`[a-zA-Z]+(?:[a-z]+)?",
        "L'[A-Za-z]+\\\\\\^[a-z](?:[a-z]+)?"
      ]
    }
  ],
